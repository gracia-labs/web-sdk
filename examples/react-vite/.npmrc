# The SDK's peerDependencies list @react-three/fiber@">=9.0.0", but
# R3F v9 requires React 19.  With React 18 we must use R3F v8, which
# conflicts with the SDK's peer spec.  This flag tells npm to accept
# the mismatch (it works — R3F is an optional peer and v8 is compatible).
#
# pnpm and yarn handle this automatically; only npm needs this flag.
legacy-peer-deps=true
